{
  "name": "zenput",
  "version": "1.1.1",
  "description": "Zenput — a production-ready, accessible React TypeScript input components library",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./forms": {
      "import": "./dist/esm/forms/index.js",
      "require": "./dist/cjs/forms/index.js",
      "types": "./dist/forms/index.d.ts"
    },
    "./tokens": {
      "react-server": "./dist/esm/tokens/index.js",
      "import": "./dist/esm/tokens/index.js",
      "require": "./dist/cjs/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    },
    "./server": {
      "react-server": "./dist/esm/server/index.js",
      "import": "./dist/esm/server/index.js",
      "require": "./dist/cjs/server/index.js",
      "types": "./dist/server/index.d.ts"
    },
    "./locales": {
      "import": "./dist/esm/locales/index.js",
      "require": "./dist/cjs/locales/index.js",
      "types": "./dist/locales/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit",
    "test:storybook": "test-storybook",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "type-check": "tsc --noEmit",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "@hookform/resolvers": ">=3.0.0",
    "react-hook-form": ">=7.0.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@hookform/resolvers": { "optional": true },
    "react-hook-form": { "optional": true },
    "zod": { "optional": true }
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.12.0",
    "@hookform/resolvers": "^5.2.2",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-webpack5": "^10.3.5",
    "@storybook/test-runner": "^0.24.3",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "axe-playwright": "^2.0.1",
    "babel-loader": "^10.1.1",
    "eslint": "^9.12.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.2",
    "prettier": "^3.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.0",
    "size-limit": "^12.1.0",
    "storybook": "^10.3.5",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0",
    "vitest": "^4.1.5",
    "vitest-axe": "^0.1.0"
  },
  "keywords": [
    "react",
    "input",
    "components",
    "typescript",
    "accessible",
    "form",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/konarsubhojit/zenput"
  },
  "author": "konarsubhojit"
}
